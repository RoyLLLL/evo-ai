def setup_a2a_server():
    # 构建 AgentCard（可动态从 DB）
    agent_card = AgentCard(
        name="Evo AI Agent",
        description="Evolution API A2A Agent",
        url="https://your-domain.com/a2a/",  # 你的实际域名
        version="1.0.0",
        protocol_version="0.3.0",
        capabilities=AgentCapabilities(
            streaming=True,
            push_notifications=True,
        ),
        skills=[
            AgentSkill(
                id="general-assistance",
                name="General Assistance",
                description="Handles queries and multi-turn conversations",
                # 可添加 examples, input_schema 等
            )
        ],
        # default_input_modes 等可选字段
    )

    # Push 配置存储（内存示例，生产用 DB-backed）
    push_config_store = InMemoryPushNotificationConfigStore()
    push_sender = BasePushNotificationSender(httpx.AsyncClient(), push_config_store)

    # 创建自定义 handler
    handler = EvoRequestHandler(
        push_config_store=push_config_store,
        push_sender=push_sender,
        # task_store=... 如果需要自定义 task 存储
    )

    # 创建 A2A 子应用
    a2a_app = A2AStarletteApplication(
        agent_card=agent_card,
        http_handler=handler,
    )

    return a2a_app.build()  # 返回 ASGI app，用于 mount

